# chronomaxi self-hosted Convex -- environment template.
# Copy to deploy/.env (docker compose --env-file) and/or repo-root .env.local
# (Convex CLI) as noted per variable. NEVER commit the filled-in file.

# --- consumed by deploy/docker-compose.yml (docker compose --env-file deploy/.env) ---

# Postgres password for the `convex` role. Generate with: openssl rand -hex 24
CONVEX_PG_PASSWORD=changeme-generate-with-openssl-rand-hex-24

# Convex backend root identity secret. Generate with: openssl rand -hex 32
CONVEX_INSTANCE_SECRET=changeme-generate-with-openssl-rand-hex-32

# --- consumed by the Convex CLI (repo-root .env.local, `bunx convex dev/deploy`) ---

# Base URL of the self-hosted backend's sync/HTTP-client port (3210 by
# default). Local validation: http://127.0.0.1:3210
# Production (big-bertha, tailnet): http://big-bertha:3210
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210

# Printed once by: docker compose -f deploy/docker-compose.yml exec backend \
#   ./generate_admin_key.sh
# Authenticates the CLI/dashboard against the self-hosted backend above --
# treat exactly like a root password.
CONVEX_SELF_HOSTED_ADMIN_KEY=changeme-generate-with-generate_admin_key.sh

# --- consumed as a Convex deployment env var, NOT a shell/compose var ---
# Set on the deployment itself with:
#   bunx convex env set CHRONOMAXI_INGEST_SECRET <value> \
#     --url "$CONVEX_SELF_HOSTED_URL" --admin-key "$CONVEX_SELF_HOSTED_ADMIN_KEY"
# Checked by convex/http.ts as the bearer token for POST /ingest and
# POST /session-event. Generate with: openssl rand -hex 32
CHRONOMAXI_INGEST_SECRET=changeme-generate-with-openssl-rand-hex-32
