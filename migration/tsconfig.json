{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext"],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "types": ["bun-types"],
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "fixtures/*.sqlite", ".checkpoints"]
}
