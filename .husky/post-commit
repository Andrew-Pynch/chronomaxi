#!/bin/sh
# .husky/post-commit -- auto-push + fleet-deploy on every commit landed on
# main. Exits 0 immediately (fast, no side effects) for any other branch,
# or when opted out. Never blocks the commit: the actual deploy is spawned
# fully detached (setsid nohup ... &); its output goes to
# ~/.local/state/chronomaxi/fleet-deploy.log, not this hook's stdout, so
# `git commit` returns instantly regardless of how long the deploy takes.
#
# Opt-outs (either skips the deploy for that one commit):
#   HUSKY=0 git commit -m "wip"                  (skips ALL husky hooks)
#   CHRONOMAXI_NO_DEPLOY=1 git commit -m "wip"    (skips just this deploy)
#
# Run via husky v9's core.hooksPath shim (.husky/_/h), which invokes this
# file with `sh -e` regardless of its shebang -- kept POSIX sh, no
# bashisms.

branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || exit 0
[ "$branch" = "main" ] || exit 0
[ "${HUSKY-}" = "0" ] && exit 0
[ "${CHRONOMAXI_NO_DEPLOY-}" = "1" ] && exit 0

repo_root=$(git rev-parse --show-toplevel) || exit 0
log_dir="$HOME/.local/state/chronomaxi"
mkdir -p "$log_dir"

setsid nohup "$repo_root/deploy/fleet-deploy.sh" >>"$log_dir/fleet-deploy.log" 2>&1 &

exit 0
